<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane styleClass="login-root" prefWidth="600" prefHeight="450" 
           stylesheets="@/css/style.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.lab.lms.controllers.LoginController">
    
    <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="login-card-container">
        <!-- Vertical Clinical Ribbon (Medical Red) -->
        <VBox styleClass="login-ribbon" />
        
        <!-- Login Form Content -->
        <VBox spacing="25" alignment="CENTER" prefWidth="420" style="-fx-padding: 40 60; -fx-background-color: white;">
            
            <!-- Branding Header -->
            <VBox spacing="4" alignment="CENTER">
                <Label text="LAB LMS 1.0" styleClass="login-title" />
                <Label text="MSF DIGITAL SOLUTIONS (SMC-PRIVATE) LIMITED" styleClass="login-tagline" />
            </VBox>
            
            <!-- Primary Auth Area -->
            <VBox spacing="15" alignment="CENTER" maxWidth="300">
                <VBox spacing="2">
                    <Label text="USER CREDENTIALS" style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #961111; -fx-letter-spacing: 1;"/>
                    <TextField fx:id="usernameField" promptText="Enter clinical identity..." styleClass="login-input-box" />
                </VBox>
                
                <VBox spacing="2">
                    <Label text="SECURITY ACCESS" style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #961111; -fx-letter-spacing: 1;"/>
                    <HBox spacing="0" alignment="CENTER_LEFT">
                        <StackPane HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="passwordField" promptText="Enter secure key..." styleClass="login-input-box" />
                            <TextField fx:id="passwordTextField" managed="false" visible="false" promptText="Enter secure key..." styleClass="login-input-box" />
                        </StackPane>
                        <Button fx:id="eyeBtn" onAction="#togglePasswordVisibility" text="👁" 
                                style="-fx-background-color: transparent; -fx-text-fill: #961111; -fx-font-size: 16; -fx-cursor: hand; -fx-padding: 0 5 0 5;"/>
                    </HBox>
                </VBox>
                
                <Button fx:id="loginBtn" text="AUTHENTICATE &amp; ENTER" onAction="#handleLogin" 
                        styleClass="login-btn-primary" prefWidth="300" />
                
                <Label fx:id="errorLabel" wrapText="true" alignment="CENTER" style="-fx-text-fill: #B71C1C; -fx-font-size: 10; -fx-font-weight: bold;"/>
            </VBox>
            
            <!-- Network Settings Block (Toggled) -->
            <VBox fx:id="ipContainer" spacing="12" alignment="CENTER" managed="false" visible="false" 
                  style="-fx-padding: 15; -fx-background-color: #F9F2F2; -fx-border-color: #CFD8DC; -fx-border-width: 1;">
                <VBox spacing="2" alignment="CENTER_LEFT" maxWidth="280">
                   <Label text="MAIN SERVER IP (Wi-Fi/LAN)" style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #961111;"/>
                   <TextField fx:id="ipField" promptText="Enter Server IP..." styleClass="login-input-box" />
                </VBox>
                
                <VBox spacing="2" alignment="CENTER">
                    <Label fx:id="localIpLabel" text="LOCAL IP: Identifying..." style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #78909C;"/>
                </VBox>

                <Button text="CONNECT TO CLINICAL SERVER" onAction="#handleConnect" 
                        prefWidth="280" styleClass="login-btn-primary" style="-fx-font-size: 11; -fx-padding: 10 0;"/>
            </VBox>

            <!-- Navigation Tools -->
            <VBox alignment="CENTER" spacing="5">
                <Hyperlink fx:id="networkSettingsLink" text="NETWORK SETTINGS" onAction="#handleToggleNetworkUI" 
                           managed="false" visible="false"
                           style="-fx-font-size: 10; -fx-text-fill: #961111; -fx-font-weight: bold; -fx-underline: false;"/>
                <Label text="System Integrity Control v1.2" style="-fx-font-size: 8; -fx-text-fill: #CFD8DC;"/>
            </VBox>
            
        </VBox>
    </HBox>
    
</StackPane>
