<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.web.HTMLEditor?>
<?import javafx.scene.image.ImageView?>

<VBox spacing="0" stylesheets="@/css/style.css"
      style="-fx-background-color: #F9F2F2; -fx-padding: 15 20 10 20;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lab.lms.controllers.AdminController">

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 12 0;">
        <VBox spacing="2">
            <Label text="System Administration &amp; Configuration" styleClass="page-title"/>
            <Label text="Management of clinical test catalogue, system security, and database integrity"
                   style="-fx-text-fill: #2C3E50; -fx-font-size: 12;"/>
        </VBox>
    </HBox>

    <TabPane fx:id="adminTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
             style="-fx-tab-min-height: 42; -fx-tab-max-height: 42;">
        <tabs>

            <!-- ===== TAB 1: Test Repository ===== -->
            <Tab fx:id="tabTests" text=" TEST REPOSITORY ">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #F9F2F2;">
                    <StackPane alignment="TOP_CENTER" style="-fx-padding: 25; -fx-background-color: #F9F2F2;">
                        <VBox spacing="0" alignment="TOP_CENTER" maxWidth="Infinity" styleClass="card">
                            <!-- Single Cohesive Container for Test Repository -->
                            <VBox spacing="25">
                                <VBox spacing="6">
                                    <Label text="TEST SPECIFICATION PROTOCOL" styleClass="section-title" style="-fx-text-fill: #961111;"/>
                                    <Label text="Configure primary diagnostic parameters and clinical categories." 
                                           style="-fx-font-size: 11; -fx-text-fill: #78909C;"/>
                                </VBox>
                                
                                <GridPane vgap="20" hgap="30">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                    </columnConstraints>

                                    <!-- Row 0: Name and Department -->
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label text="PROTOCOL NAME" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="nameField" promptText="e.g. Full Blood Count"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label text="DEPARTMENT / CATEGORY" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <ComboBox fx:id="categoryField" promptText="Select Category" maxWidth="Infinity" editable="true"/>
                                    </VBox>

                                    <!-- Row 1: Codes -->
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                        <Label text="TEST DIGIT CODE" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="numericCodeField" promptText="e.g. 101"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                        <Label text="ALPHA CODE" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="alphaCodeField" promptText="e.g. FBC"/>
                                    </VBox>

                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                        <Label text="UNIT PRICE (PKR)" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="priceField" promptText="500.00"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                        <Label text="EXPECTED TAT" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <HBox spacing="5">
                                            <TextField fx:id="resultTimeField" promptText="e.g. 4" HBox.hgrow="ALWAYS"/>
                                            <ComboBox fx:id="tatUnitBox" prefWidth="100"/>
                                        </HBox>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                        <Label text="SPECIMEN TYPE" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="specimenField" promptText="e.g. Blood, Urine, etc."/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                        <Label text="REFERENCE IMAGE (OPTIONAL)" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <Label fx:id="testImagePathLabel" text="No image attached" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                   style="-fx-background-color: #FDFDFD; -fx-padding: 8; -fx-border-color: #CFD8DC; -fx-text-fill: #78909C; -fx-font-size: 10;"/>
                                            <Button text="UPLOAD" onAction="#handleUploadTestImage" styleClass="button-secondary" prefHeight="35"/>
                                            <Button text="DEL" onAction="#handleRemoveTestImage" styleClass="button-secondary" prefHeight="35" style="-fx-background-color: #B0BEC5;"/>
                                        </HBox>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="4" alignment="CENTER_LEFT">
                                        <Label text="PROTOCOL CLASS / CATEGORY" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <ComboBox fx:id="testClassBox" prefWidth="400" promptText="Select Class"/>
                                    </VBox>
                                    <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4" alignment="CENTER_LEFT">
                                        <HBox spacing="15" alignment="CENTER_LEFT">
                                            <CheckBox fx:id="isSpecialCheck" text="MARK AS SPECIAL TEST" 
                                                      style="-fx-font-weight: bold; -fx-text-fill: #961111; -fx-font-size: 10;"/>
                                            <CheckBox fx:id="isMicroscopicCheck" text="MARK AS MICROSCOPIC" 
                                                      style="-fx-font-weight: bold; -fx-text-fill: #1A0A0A; -fx-font-size: 10;"/>
                                            <CheckBox fx:id="isCultureCheck" text="MARK AS CULTURE" 
                                                      style="-fx-font-weight: bold; -fx-text-fill: #1A0A0A; -fx-font-size: 10;"/>
                                        </HBox>
                                    </VBox>
                                </GridPane>
                                <VBox spacing="8">
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <Label text="CLINICAL NOTES &amp; INTERPRETATIONS" styleClass="section-title" style="-fx-font-size: 10;"/>
                                    </HBox>
                                    <HTMLEditor fx:id="testNotesArea" prefHeight="250" style="-fx-font-size: 12;"/>
                                </VBox>

                                <Separator/>

                                <VBox spacing="15">
                                    <Label text="CLINICAL PARAMETER DEFINITION" styleClass="section-title" style="-fx-text-fill: #961111;"/>
                                    <VBox spacing="10">
                                        <GridPane hgap="15" vgap="4">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="22"/>
                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
                                                <ColumnConstraints hgrow="ALWAYS" percentWidth="28"/>
                                            </columnConstraints>

                                            <!-- Row 1: Basic Info and General Range -->
                                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                <Label fx:id="paramNameLabel" text="PARAMETER NAME" styleClass="section-title" style="-fx-font-size: 9;"/>
                                                <TextField fx:id="paramNameField" promptText="e.g. Hemoglobin" maxWidth="Infinity"/>
                                            </VBox>
                                            <VBox fx:id="unitInputBox" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                <Label text="UNIT" styleClass="section-title" style="-fx-font-size: 9;"/>
                                                <TextField fx:id="paramUnitField" promptText="g/dL" maxWidth="Infinity"/>
                                            </VBox>
                                            
                                            <VBox fx:id="referenceValueBox" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <Label fx:id="minLabel" text="REGULAR RANGES" styleClass="section-title" style="-fx-font-size: 9;"/>
                                                    <Button text="+ NEW" onAction="#handleNewRangeGeneral" style="-fx-font-size: 8; -fx-padding: 1 6; -fx-background-color: transparent; -fx-border-color: #961111; -fx-border-radius: 3; -fx-text-fill: #961111; -fx-font-weight: bold; -fx-cursor: hand;"/>
                                                </HBox>
                                                <VBox fx:id="containerGeneralRange" spacing="3">
                                                    <HBox spacing="6" alignment="CENTER_LEFT">
                                                        <VBox fx:id="minInputBox" spacing="2">
                                                            <TextField fx:id="paramMinField"  promptText="Min" prefWidth="150" maxWidth="150"/>
                                                        </VBox>
                                                        <VBox fx:id="maxInputBox" spacing="2">
                                                            <TextField fx:id="paramMaxField"  promptText="Max" prefWidth="150" maxWidth="150"/>
                                                        </VBox>
                                                    </HBox>
                                                </VBox>
                                            </VBox>

                                            <HBox spacing="15" alignment="BOTTOM_RIGHT" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                                <Button fx:id="btnAddParameter" text="+ ADD PARAMETER TO PROTOCOL" onAction="#handleAddParameter" 
                                                        style="-fx-background-color: #961111; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 11; -fx-padding: 10 25;"
                                                        maxWidth="Infinity"/>
                                            </HBox> 

                                            <!-- Row 2: Kid, Male, and Female Ranges -->
                                            <VBox fx:id="kidsRangeBox" spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <Label text="KIDS RANGES" styleClass="section-title" style="-fx-font-size: 9; -fx-text-fill: #1A0A0A;"/>
                                                    <Button text="+ NEW" onAction="#handleNewRangeKids" style="-fx-font-size: 8; -fx-padding: 1 6; -fx-background-color: transparent; -fx-border-color: #961111; -fx-border-radius: 3; -fx-text-fill: #961111; -fx-font-weight: bold; -fx-cursor: hand;"/>
                                                </HBox>
                                                <VBox fx:id="containerKidsRange" spacing="3">
                                                    <HBox spacing="6" alignment="CENTER_LEFT">
                                                        <TextField fx:id="paramMinKidsField"  promptText="Min" prefWidth="150" maxWidth="150"/>
                                                        <TextField fx:id="paramMaxKidsField"  promptText="Max" prefWidth="150" maxWidth="150"/>
                                                    </HBox>
                                                </VBox>
                                            </VBox>

                                            <VBox fx:id="maleRangeBox" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <Label text="MALE RANGES" styleClass="section-title" style="-fx-font-size: 9; -fx-text-fill: #1A0A0A;"/>
                                                    <Button text="+ NEW" onAction="#handleNewRangeMale" style="-fx-font-size: 8; -fx-padding: 1 6; -fx-background-color: transparent; -fx-border-color: #961111; -fx-border-radius: 3; -fx-text-fill: #961111; -fx-font-weight: bold; -fx-cursor: hand;"/>
                                                </HBox>
                                                <VBox fx:id="containerMaleRange" spacing="3">
                                                    <HBox spacing="6" alignment="CENTER_LEFT">
                                                        <TextField fx:id="paramMinMaleField"  promptText="Min" prefWidth="150" maxWidth="150"/>
                                                        <TextField fx:id="paramMaxMaleField"  promptText="Max" prefWidth="150" maxWidth="150"/>
                                                    </HBox>
                                                </VBox>
                                            </VBox>
                                            
                                            <VBox fx:id="femaleRangeBox" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                    <Label text="FEMALE RANGES" styleClass="section-title" style="-fx-font-size: 9; -fx-text-fill: #1A0A0A;"/>
                                                    <Button text="+ NEW" onAction="#handleNewRangeFemale" style="-fx-font-size: 8; -fx-padding: 1 6; -fx-background-color: transparent; -fx-border-color: #961111; -fx-border-radius: 3; -fx-text-fill: #961111; -fx-font-weight: bold; -fx-cursor: hand;"/>
                                                </HBox>
                                                <VBox fx:id="containerFemaleRange" spacing="3">
                                                    <HBox spacing="6" alignment="CENTER_LEFT">
                                                        <TextField fx:id="paramMinFemaleField"  promptText="Min" prefWidth="150" maxWidth="150"/>
                                                        <TextField fx:id="paramMaxFemaleField"  promptText="Max" prefWidth="150" maxWidth="150"/>
                                                    </HBox>
                                                </VBox>
                                            </VBox>

                                            <!-- Row 3: Action Buttons and Microscopic Category (Repurposed Row) -->
                                            <VBox fx:id="categoryInputBox" spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0" managed="false" visible="false">
                                                <Label fx:id="paramCategoryLabel" text="EXAMINATION CATEGORY" styleClass="section-title" style="-fx-font-size: 9;"/>
                                                <ComboBox fx:id="paramCategoryField" promptText="Select Category" maxWidth="Infinity" editable="true"/>
                                            </VBox>

                                            <VBox fx:id="cultureTypeInputBox" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0" managed="false" visible="false">
                                                <Label text="CULTURE TYPE (SPECIMEN)" styleClass="section-title" style="-fx-font-size: 9;"/>
                                                <ComboBox fx:id="cultureTypeField" promptText="e.g. Urine Culture" maxWidth="Infinity" editable="true"/>
                                            </VBox>
                                                                                         
                                             <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="4">
                                                 <Label text="ADDITIONAL REFERENCE RANGES (ONE PER LINE - e.g. Neonatal: 0-5)" styleClass="section-title" style="-fx-font-size: 9; -fx-text-fill: #961111;"/>
                                                 <TextArea fx:id="secondaryRangesArea" prefHeight="50" promptText="Enter each additional range on a NEW line..." wrapText="true" style="-fx-font-size: 11;"/>
                                             </VBox>
                                        </GridPane>

                                        <TableView fx:id="paramTable" prefHeight="180" minHeight="180">
                                             <columns>
                                                 <TableColumn fx:id="colParamSelect" text="SEL" prefWidth="50" minWidth="40" style="-fx-alignment: CENTER;"/>
                                                 <TableColumn fx:id="colParamName"  text="PARAMETER" prefWidth="250" minWidth="200"/>
                                                <TableColumn fx:id="colParamUnit"  text="UNIT"      prefWidth="100" minWidth="80" style="-fx-alignment: CENTER;"/>
                                                <TableColumn fx:id="colParamCategory" text="EXAMINATION CATEGORY" prefWidth="150" minWidth="100" style="-fx-alignment: CENTER;"/>
                                                <TableColumn fx:id="colParamRange" text="REFERENCE DISCLOSURE" prefWidth="250" minWidth="200" style="-fx-alignment: CENTER;"/>
                                            </columns>
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                        </TableView>

                                        <HBox spacing="15" alignment="CENTER_RIGHT">
                                            <Button text="REMOVE SELECTED PARAMETER" onAction="#handleRemoveParameter" 
                                                    styleClass="button-secondary" prefHeight="35"/>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button text="PREVIEW TEST LAYOUT" onAction="#handlePreviewTest" 
                                                    styleClass="button-secondary" prefWidth="180" prefHeight="35" style="-fx-background-color: #546E7A; -fx-text-fill: white;"/>
                                            <Button text="DISCARD CHANGES" onAction="#handleDelete" 
                                                    styleClass="button-secondary" prefWidth="150" prefHeight="35" style="-fx-background-color: #78909C;"/>
                                            <Button text="AUTHORIZE &amp; SAVE PROTOCOL" onAction="#handleSave" 
                                                    styleClass="button-primary" prefWidth="250" prefHeight="40"/>
                                        </HBox>
                                    </VBox>
                                </VBox>
                                
                                <Separator style="-fx-padding: 10 0;"/>
                                
                                <!-- Test-Inventory Association -->
                                <VBox spacing="15">
                                    <Label text="ASSOCIATED CLINICAL CONSUMABLES (AUTO-DEDUCT)" styleClass="section-title" style="-fx-text-fill: #1A0A0A;"/>
                                    <HBox spacing="10" alignment="BOTTOM_LEFT">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="SELECT INVENTORY ITEM" styleClass="section-title" style="-fx-font-size: 9;"/>
                                            <ComboBox fx:id="testInventoryItemBox" promptText="Select Reagent/Item" maxWidth="Infinity"/>
                                        </VBox>
                                        <VBox spacing="5">
                                            <Label text="QTY USED" styleClass="section-title" style="-fx-font-size: 9;"/>
                                            <TextField fx:id="testInventoryQtyField" promptText="1.0" prefWidth="100"/>
                                        </VBox>
                                        <Button text="+ LINK" onAction="#handleLinkInventory" styleClass="button-primary" style="-fx-background-color: #961111;" prefHeight="35"/>
                                    </HBox>
                                    
                                    <TableView fx:id="linkedInventoryTable" prefHeight="120" minHeight="120">
                                        <columns>
                                            <TableColumn fx:id="colLinkedInvName" text="CONSUMABLE" prefWidth="250"/>
                                            <TableColumn fx:id="colLinkedInvQty"  text="QTY PER TEST" prefWidth="150" style="-fx-alignment: CENTER;"/>
                                            <TableColumn fx:id="colLinkedInvAction" text="ACTION" prefWidth="100" style="-fx-alignment: CENTER;"/>
                                        </columns>
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                    </TableView>
                                </VBox>
                                
                                <Separator style="-fx-padding: 10 0;"/>

                                <!-- Clinical Inventory Part (Now integrated at the bottom) -->
                                <VBox spacing="15" VBox.vgrow="ALWAYS">
                                    <HBox spacing="20" alignment="CENTER_LEFT">
                                        <Label text="ROUTINE &amp; PREMIUM CLINICAL INVENTORY" styleClass="section-title" style="-fx-text-fill: #961111;"/>
                                        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 20;">
                                            <ToggleButton fx:id="btnRoutineFilter" text="ROUTINE" styleClass="filter-toggle"/>
                                            <ToggleButton fx:id="btnPremiumFilter" text="PREMIUM" styleClass="filter-toggle"/>
                                        </HBox>
                                        <Button text="PRINT RATE LIST" onAction="#handlePrintRateList"
                                                style="-fx-background-color: #961111; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <TextField fx:id="testSearchField" promptText="Search Diagnostic Protocol..." 
                                                   styleClass="medical-search-bar" prefWidth="350"/>
                                    </HBox>
                                    <TableView fx:id="testTable" VBox.vgrow="ALWAYS" minHeight="400">
                                        <columns>
                                            <TableColumn fx:id="colNumericCode" text="CODE"           prefWidth="55"  minWidth="50" style="-fx-alignment: CENTER;"/>
                                            <TableColumn fx:id="colAlphaCode"   text="ALPHA"          prefWidth="85"  minWidth="80" style="-fx-alignment: CENTER;"/>
                                            <TableColumn fx:id="colName"        text="TEST DESCRIPTION" prefWidth="300" minWidth="200"/>
                                            <TableColumn fx:id="colPrice"       text="PRICE (PKR)"     prefWidth="120" minWidth="80" style="-fx-alignment: CENTER-RIGHT;"/>
                                            <TableColumn fx:id="colTAT"         text="LEAD TIME"       prefWidth="120" minWidth="80" style="-fx-alignment: CENTER;"/>
                                            <TableColumn fx:id="colAction"      text="ACTION"          prefWidth="80" minWidth="80" style="-fx-alignment: CENTER;"/>
                                        </columns>
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                    </TableView>
                                </VBox>
                            </VBox>
                        </VBox>
                    </StackPane>
                </ScrollPane>
            </Tab>

            <!-- ===== TAB 2: Laboratorians ===== -->
            <Tab fx:id="tabStaff" text=" LABORATORIANS ">
                <ScrollPane fitToWidth="true" style="-fx-background-color: #F9F2F2;">
                    <StackPane alignment="TOP_CENTER" style="-fx-padding: 25; -fx-background-color: #F9F2F2;">
                        <VBox spacing="0" alignment="TOP_CENTER" maxWidth="Infinity" styleClass="card">
                            <!-- Single Cohesive Container for Laboratorian Management -->
                            <VBox spacing="25">
                                <VBox spacing="6">
                                    <Label text="AGENT REGISTRATION &amp; PERSONNEL DATA" styleClass="section-title" style="-fx-text-fill: #961111;"/>
                                    <Label text="Register clinical personnel and configure secure system access privileges." 
                                           style="-fx-font-size: 11; -fx-text-fill: #78909C;"/>
                                </VBox>
                                
                                <GridPane vgap="20" hgap="30">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33"/>
                                    </columnConstraints>

                                    <!-- Row 0: Identity Info -->
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label text="FULL NAME" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="staffNameField" promptText="e.g. Dr. Sarah Jenkins"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label text="DESIGNATION" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="staffDesignationField" promptText="e.g. Senior Technologist"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                        <Label text="CONTACT NUMBER" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="staffPhoneField" promptText="+92 XXX XXXXXXX"/>
                                    </VBox>

                                    <!-- Row 1: Professional Background -->
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                        <Label text="QUALIFICATION" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextField fx:id="staffQualField" promptText="e.g. MBBS, M.Phil Hematology"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                        <Label text="DATE OF BIRTH" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <DatePicker fx:id="staffDobPicker" maxWidth="Infinity"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                        <Label text="GENDER" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <ComboBox fx:id="staffGenderBox" promptText="Select Gender" maxWidth="Infinity"/>
                                    </VBox>

                                    <!-- Row 2: Security and Profile Image -->
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                        <Label text="SECURE ACCESS PASSWORD" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <PasswordField fx:id="staffPassField" promptText="••••••••"/>
                                    </VBox>
                                    <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.columnSpan="2">
                                        <Label text="PROFILE PICTURE (UPLOAD OR CAPTURE)" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <HBox spacing="15" alignment="CENTER_LEFT">
                                            <StackPane style="-fx-background-color: #ECEFF1; -fx-border-color: #CFD8DC; -fx-border-width: 1; -fx-min-width: 70; -fx-min-height: 70; -fx-max-width: 70; -fx-max-height: 70;">
                                                <ImageView fx:id="staffImageView" fitWidth="68" fitHeight="68" preserveRatio="true"/>
                                            </StackPane>
                                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                                 <Label fx:id="staffImagePathLabel" text="No image attached" style="-fx-font-size: 9; -fx-text-fill: #90A4AE;"/>
                                                 <HBox spacing="8">
                                                     <Button text="UPLOAD" onAction="#handleUploadStaffPic" styleClass="button-secondary" style="-fx-font-size: 9; -fx-padding: 4 10;"/>
                                                 </HBox>
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                    <!-- Row 3: Address full span -->
                                    <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="3">
                                        <Label text="OFFICIAL RESIDENT ADDRESS" styleClass="section-title" style="-fx-font-size: 10;"/>
                                        <TextArea fx:id="staffAddressField" promptText="Full permanent address of the registered personnel..." prefHeight="65" wrapText="true"/>
                                    </VBox>
                                </GridPane>

                                <Separator/>

                                <!-- Access Privileges Section -->
                                <VBox spacing="15">
                                    <Label text="ACCESS PRIVILEGES &amp; SYSTEM PERMISSIONS" styleClass="section-title" style="-fx-text-fill: #961111;"/>
                                    <FlowPane hgap="30" vgap="15">
                                        <CheckBox fx:id="permDashboard" text="DASHBOARD ANALYTICS" selected="true" style="-fx-font-size: 11;"/>
