                                                     <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0; -fx-border-color: #CFD8DC; -fx-border-width: 1 0 0 0;">
                                                         <VBox spacing="4" HBox.hgrow="ALWAYS">
                                                             <Label text="DAILY CASHBOOK / SUMMARY PRINTER (RECEIPT STYLE)" styleClass="section-title" style="-fx-font-size: 9; -fx-text-fill: #961111;"/>
                                                             <ChoiceBox fx:id="cashbookPrinterSelector" maxWidth="Infinity" prefHeight="45"
                                                                    style="-fx-background-color: #FDFDFD; -fx-padding: 5; -fx-border-color: #CFD8DC; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                                         </VBox>
                                                     </HBox>
                                                 </VBox>                      
                                            </VBox>
                                            
                                        </GridPane>
                                    </VBox>
                                </GridPane>
                                
                                 <Separator/>

                                 <!-- Report Branding Dimensions & Verification -->
                                 <VBox spacing="25">
                                     <VBox spacing="6">
                                         <Label text="REPORT BRANDING DIMENSIONS &amp; VERIFICATION" styleClass="section-title" style="-fx-text-fill: #961111;"/>
                                         <Label text="Fine-tune the height of your header/footer images and enable electronic verification notes." 
                                                style="-fx-font-size: 11; -fx-text-fill: #78909C;"/>
                                     </VBox>
                                     <HBox spacing="30" alignment="CENTER_LEFT">
                                         <VBox spacing="8">
                                             <Label text="HEADER HEIGHT (PX)" styleClass="section-title" style="-fx-font-size: 10;"/>
                                             <TextField fx:id="headerHeightField" promptText="e.g. 120" prefWidth="150" />
                                         </VBox>
                                         <VBox spacing="8">
                                             <Label text="FOOTER HEIGHT (PX)" styleClass="section-title" style="-fx-font-size: 10;"/>
                                             <TextField fx:id="footerHeightField" promptText="e.g. 80" prefWidth="150" />
                                         </VBox>
                                         <VBox spacing="8" alignment="BOTTOM_CENTER">
                                             <CheckBox fx:id="toggleElectronicVerify" text="Enable Electronic Verification Note" 
                                                       style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                                         </VBox>
                                         <VBox spacing="8" alignment="BOTTOM_CENTER">
                                             <CheckBox fx:id="toggleFooter" text="Enable Footer" 
                                                       style="-fx-font-weight: bold; -fx-font-size: 13;"/>
                                         </VBox>
                                         <Region HBox.hgrow="ALWAYS" />
                                         <VBox spacing="8" alignment="BOTTOM_CENTER">
                                             <Button text="SAVE DIMENSIONS" onAction="#handleSaveSystemIntegrity" 
                                                     styleClass="button-primary" prefWidth="250" prefHeight="42" />
                                         </VBox>
                                     </HBox>
                                 </VBox>

                                 <Separator/>

                                 <!-- Administrator Access Security -->
                                 <VBox spacing="25">
                                     <VBox spacing="6">
                                         <Label text="ADMINISTRATOR ACCESS SECURITY" styleClass="section-title" style="-fx-text-fill: #961111;"/>
                                         <Label text="Modify the root administrative credentials used for system-wide configuration access." 
                                                style="-fx-font-size: 11; -fx-text-fill: #78909C;"/>
                                     </VBox>
                                     
                                     <GridPane hgap="30" vgap="20">
                                         <columnConstraints>
                                             <ColumnConstraints percentWidth="33"/>
                                             <ColumnConstraints percentWidth="33"/>
                                             <ColumnConstraints percentWidth="33"/>
                                         </columnConstraints>
                                         
                                         <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                             <Label text="ADMIN USERNAME" styleClass="section-title" style="-fx-font-size: 10;"/>
                                             <TextField fx:id="adminUsernameField" promptText="Enter current or new username"/>
                                         </VBox>
                                         <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                             <Label text="NEW PASSWORD" styleClass="section-title" style="-fx-font-size: 10;"/>
                                             <PasswordField fx:id="adminPasswordField"  promptText="••••••••"/>
                                         </VBox>
                                         <VBox spacing="8" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                             <Label text="CONFIRM PASSWORD" styleClass="section-title" style="-fx-font-size: 10;"/>
                                             <PasswordField fx:id="adminConfirmPasswordField" promptText="••••••••"/>
                                         </VBox>
                                     </GridPane>
                                     <HBox alignment="CENTER_RIGHT">
                                         <Button text="UPDATE ACCESS CREDENTIALS" onAction="#handleUpdateAdminCredentials" 
                                                 styleClass="button-primary" prefWidth="300" prefHeight="42" style="-fx-background-color: #920E0E;"/>
                                     </HBox>
                                 </VBox>
                                 
                                 <Separator/>
                                 
                                 <Label text="Clinical environment monitoring: Active | Connectivity: LAN Optimized" 
                                        style="-fx-font-size: 10; -fx-text-fill: #961111; -fx-alignment: CENTER; -fx-max-width: Infinity;"/>
                            </VBox>
                        </VBox>
                    </StackPane>
                </ScrollPane>
            </Tab>
        </tabs>
    </TabPane>
</VBox>


