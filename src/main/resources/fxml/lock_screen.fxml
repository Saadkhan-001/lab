<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0" stylesheets="@/css/style.css"
      style="-fx-background-color: white;"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lab.lms.controllers.LockScreenController">

    <!-- Header Block -->
    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #961111; -fx-padding: 40 20;" maxWidth="Infinity">
        <Label text="DIAGNOSTIC BLOCKADE ACTIVE" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-letter-spacing: 2px; -fx-font-size: 11;"/>
        <Label text="SYSTEM LOCKED" style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
        <Label fx:id="systemIdLabel" text="LAB-XXXX-XXXX" style="-fx-text-fill: white; -fx-opacity: 0.7; -fx-font-family: 'Consolas';"/>
    </VBox>

    <VBox spacing="30" alignment="CENTER" VBox.vgrow="ALWAYS" style="-fx-padding: 40;">
        
        <VBox spacing="15" maxWidth="500" alignment="CENTER">
            <Label text="LICENSE EXPIRATION DETECTED" styleClass="section-title" style="-fx-text-fill: #961111;"/>
            <Label text="Your laboratory clinical access has expired. Please provide a renewal key to resume full operations. Emergency reporting tools remain available below." 
                   wrapText="true" textAlignment="CENTER" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
        </VBox>

        <!-- Renewal Area -->
        <VBox spacing="10" maxWidth="500">
            <Label text="INPUT RENEWAL ACTIVATION KEY" styleClass="section-title" style="-fx-font-size: 9;"/>
            <HBox spacing="10">
                <TextField fx:id="renewalKeyField" promptText="Paste renewal key..." HBox.hgrow="ALWAYS" style="-fx-font-family: 'Consolas';"/>
                <Button text="ACTIVATE" onAction="#handleRenew" styleClass="button-primary"/>
            </HBox>
            <Label fx:id="errorLabel" style="-fx-text-fill: #961111; -fx-font-weight: bold; -fx-font-size: 11;"/>
        </VBox>

        <Separator maxWidth="500"/>

        <!-- Clinical Contingency Actions -->
        <VBox spacing="15" alignment="CENTER">
            <Label text="EMERGENCY CLINICAL TOOLS" styleClass="section-title" style="-fx-font-size: 9; -fx-text-fill: #777;"/>
            <HBox spacing="20" alignment="CENTER">
                <Button text="🖨️ PRINT BLANK TEMPLATE" onAction="#handlePrintBlank" 
                        style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-cursor: hand;"/>
                <Button text="🔍 PRINT EXISTING REPORT" onAction="#handlePrintExisting" 
                        style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

    </VBox>
    
    <!-- Footer -->
    <HBox alignment="CENTER" style="-fx-padding: 20; -fx-background-color: #f9f9f9;">
        <Label text="For technical assistance, please contact MSF Digital Solutions Support." style="-fx-font-size: 10; -fx-text-fill: #999;"/>
    </HBox>

</VBox>
