<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0" stylesheets="@/css/style.css"
      style="-fx-background-color: #F9F2F2; -fx-padding: 15 20 10 20;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lab.lms.controllers.BillingController">

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 12 0;">
        <VBox spacing="2">
            <Label text="Test Catalogue &amp; Invoicing" styleClass="page-title"/>
            <Label text="Configure diagnostics selection and generate verified clinical invoices"
                   style="-fx-text-fill: #5D4037; -fx-font-size: 12;"/>
        </VBox>
    </HBox>

    <!-- Two-Column Layout (Responsive) -->
    <GridPane vgap="20" hgap="20" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="65.0"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="35.0"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints vgrow="ALWAYS"/>
        </rowConstraints>

        <!-- LEFT: Test Selection Card -->
        <VBox spacing="20" styleClass="card" GridPane.columnIndex="0">

            <Label text="1. PATIENT &amp; TEST SELECTION" styleClass="section-title"/>

            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="SEARCH PATIENT" styleClass="section-title" style="-fx-font-size: 8;"/>
                    <TextField fx:id="patientSearchField" promptText="Name/ID/Phone" maxWidth="Infinity" onAction="#handlePatientSearch"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="QUICK SELECT" styleClass="section-title" style="-fx-font-size: 8;"/>
                    <ComboBox fx:id="recentPatientCombo" promptText="Select Recent" maxWidth="Infinity" onAction="#handleRecentSelect"/>
                </VBox>
            </HBox>

            <!-- Selected Patient Feedback -->
            <Label fx:id="patientNameLabel" text="NO PATIENT SELECTED" 
                   style="-fx-text-fill: #961111; -fx-font-weight: bold; -fx-font-size: 11;"/>

            <Separator/>


            <!-- Test Selector -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="testCombo" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                          promptText="Select diagnostic test from system catalogue..."/>
                <Button text="ADD TEST" onAction="#handleAddTest" styleClass="button-primary"/>
            </HBox>

            <!-- Selected Tests Table -->
            <Label text="ACTIVE TEST SELECTIONS" styleClass="section-title"/>
            <TableView fx:id="selectedTestsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #F9F2F2; -fx-selection-bar: transparent; -fx-selection-bar-non-focused: transparent;">
                <columns>
                    <TableColumn fx:id="colNumericCode" text="CODE"  prefWidth="55" minWidth="50" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colAlphaCode"   text="ALPHA" prefWidth="85" minWidth="80" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colTestName"    text="DIAGNOSTIC TEST NAME"  prefWidth="200"/>
                    <TableColumn fx:id="colPrice"       text="PRICE (PKR)" prefWidth="100"
                                 style="-fx-alignment: CENTER-RIGHT;"/>
                    <TableColumn fx:id="colTime"        text="TIME" prefWidth="100"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colAction"      text="ACTION" prefWidth="80"
                                 style="-fx-alignment: CENTER;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label text="No diagnostics currently selected."
                           style="-fx-text-fill: #90A4AE; -fx-font-size: 13;"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- RIGHT: Invoice Summary Card -->
        <VBox spacing="20" styleClass="card" GridPane.columnIndex="1">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="2. FINANCIAL SUMMARY" styleClass="section-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="billingSettingsBtn" text="⚙" onAction="#handleToggleSettings"
                        style="-fx-background-color: transparent; -fx-text-fill: #90A4AE; -fx-font-size: 18; -fx-padding: 0; -fx-cursor: hand;"/>
            </HBox>

            <!-- Admin Settings Panel (Hidden by default) -->
            <VBox fx:id="billingSettingsPanel" managed="false" visible="false" spacing="10" 
                  style="-fx-background-color: #ECEFF1; -fx-padding: 10; -fx-border-color: #CFD8DC; -fx-border-width: 1;">
                <Label text="DEFAULT BILLING SETTINGS" styleClass="section-title" style="-fx-font-size: 9;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Default Discount:" style="-fx-font-size: 11;"/>
                    <TextField fx:id="defaultDiscountField" prefWidth="60" text="0"/>
                    <ComboBox fx:id="defaultDiscountTypeCombo" prefWidth="80"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <CheckBox fx:id="autoPayZeroCheck" text="Auto-Pay if Paid is 0" style="-fx-font-size: 10;"/>
                    <Button text="SAVE" onAction="#handleSaveSettings" styleClass="button-primary" style="-fx-padding: 3 10;"/>
                </HBox>
            </VBox>

            <Separator/>

            <!-- Totals Box -->
            <VBox spacing="16" style="-fx-background-color: #F9F2F2; -fx-padding: 20;
                                       -fx-border-color: #CFD8DC; -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="SUBTOTAL AMOUNT" styleClass="section-title" style="-fx-font-size: 10;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalAmountLabel" text="PKR 0.00"
                           style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #961111;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="discountTypeLabel" text="DISCOUNT" styleClass="section-title" style="-fx-font-size: 10;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <HBox spacing="0">
                            <ToggleButton fx:id="btnPercent" selected="true" styleClass="toggle-button-left" focusTraversable="false"/>
                            <ToggleButton fx:id="btnCash" text="PKR" styleClass="toggle-button-right" focusTraversable="false"/>
                        </HBox>
                        <TextField fx:id="discountField" text="0" alignment="CENTER_RIGHT"
                                   prefWidth="80" style="-fx-font-weight: bold;"/>
                    </HBox>
                </HBox>

                <Separator/>

                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2">
                        <Label text="FINAL CONSOLIDATED TOTAL" styleClass="section-title" style="-fx-font-size: 11;"/>
                        <Label text="Adjusted for commercial discount" style="-fx-text-fill: #90A4AE; -fx-font-size: 10;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="finalPayableLabel" text="PKR 0.00"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #961111;"/>
                </HBox>

                <Separator/>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="PAID AMOUNT" styleClass="section-title" style="-fx-font-size: 10;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="paidAmountField" text="0" alignment="CENTER_RIGHT"
                               prefWidth="120" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1A0A0A;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT">
                    <Label text="DUE BALANCE" styleClass="section-title" style="-fx-font-size: 10;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="dueBalanceLabel" text="PKR 0.00"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #961111;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnPayAndProceed" text="CONFIRM PAYMENT &amp; PROCEED" onAction="#handleGenerateInvoice" 
                    maxWidth="Infinity" styleClass="button-primary" prefHeight="55" 
                    style="-fx-font-size: 16; -fx-font-weight: bold;"/>
        </VBox>
    </GridPane>
</VBox>


