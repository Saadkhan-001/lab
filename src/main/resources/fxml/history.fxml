<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" stylesheets="@/css/style.css"
      style="-fx-background-color: #F9F2F2; -fx-padding: 15 20 10 20;"
      VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.lab.lms.controllers.PatientHistoryController">

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 0 10 0;">
        <VBox spacing="2">
            <Label text="Longitudinal Patient Records" styleClass="page-title"/>
            <Label text="Comprehensive archive of clinical subject history and diagnostic results"
                   style="-fx-text-fill: #546E7A; -fx-font-size: 12;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="REGISTER NEW SUBJECT" onAction="#handleNewRegistration"
                styleClass="button-success" prefHeight="38"/>
    </HBox>

    <!-- Unified Filter Bar Section -->
    <VBox spacing="12" styleClass="card" style="-fx-padding: 15 20;">
        <Label text="RECORDS RETRIEVAL &amp; FILTERS" styleClass="section-title"
               style="-fx-text-fill: #961111; -fx-font-size: 11;"/>
        
        <!-- Responsive Filter Bar -->
        <GridPane vgap="12" hgap="15" alignment="BOTTOM_LEFT">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="30"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="13"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="13"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="13"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="11"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="20"/>
            </columnConstraints>

            <!-- Patient Search & Select Integrated -->
            <VBox spacing="4" GridPane.columnIndex="0">
                <Label text="1. SELECT SUBJECT (NAME / ID / PHONE)" styleClass="section-title" style="-fx-font-size: 9;"/>
                <HBox spacing="0" style="-fx-background-color: #F9F2F2; -fx-border-color: #CFD8DC; -fx-border-radius: 4;" maxWidth="Infinity">
                    <TextField fx:id="patientSearchField" promptText="Search subject..." 
                               style="-fx-border-width: 0; -fx-background-color: transparent;" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="patientSelectCombo" prefWidth="25"
                               style="-fx-background-color: transparent; -fx-border-width: 0 0 0 0;"/>
                </HBox>
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="1">
                <Label text="2. FROM DATE" styleClass="section-title" style="-fx-font-size: 9;"/>
                <DatePicker fx:id="histFilterFromDate" promptText="Start Date..." maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="2">
                <Label text="3. TO DATE" styleClass="section-title" style="-fx-font-size: 9;"/>
                <DatePicker fx:id="histFilterToDate" promptText="End Date..." maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="3">
                <Label text="4. DIAGNOSTIC TEST" styleClass="section-title" style="-fx-font-size: 9;"/>
                <ComboBox fx:id="histFilterTest" promptText="All Tests" maxWidth="Infinity"/>
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="4">
                <Label text="5. STATUS" styleClass="section-title" style="-fx-font-size: 9;"/>
                <ComboBox fx:id="histFilterStatus" promptText="All Status" maxWidth="Infinity"/>
            </VBox>

            <HBox spacing="8" alignment="BOTTOM_LEFT" GridPane.columnIndex="5">
                <Button text="APPLY" onAction="#handleHistoryFilter" 
                        styleClass="button-primary" prefHeight="32" style="-fx-font-size: 11;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button text="CLEAR" onAction="#handleHistoryClearFilter" 
                        styleClass="button-secondary" prefHeight="32" style="-fx-font-size: 11;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
        </GridPane>
    </VBox>

    <!-- Results Table Section -->
    <VBox spacing="12" styleClass="card" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="VISIT &amp; DIAGNOSTIC HISTORY" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="selectedPatientLabel" text="ALL CLINICAL RECORDS"
                   style="-fx-text-fill: #961111; -fx-font-weight: bold; -fx-font-size: 12;"/>
        </HBox>

            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #F9F2F2;">
                <columns>
                    <TableColumn fx:id="colSelect"    text="SEL"                  prefWidth="45"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colDate"       text="VISIT TIMESTAMP"      prefWidth="180"/>
                    <TableColumn fx:id="colSampleId"   text="PATIENT NAME"         prefWidth="220"
                                 style="-fx-alignment: CENTER_LEFT;"/>
                    <TableColumn fx:id="colTestName"   text="DIAGNOSTIC PROTOCOL"  prefWidth="300"/>
                    <TableColumn fx:id="colStatus"     text="STATUS"               prefWidth="130"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colAction"     text="ACTIONS"              prefWidth="130"
                                 style="-fx-alignment: CENTER;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label text="No clinical records found in the system catalogue."
                           style="-fx-text-fill: #90A4AE; -fx-font-size: 13;"/>
                </placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button fx:id="btnPrintSelected" text="🖨️ PRINT SELECTED REPORTS" onAction="#handlePrintSelectedTests"
                        visible="false" managed="false" styleClass="button-primary" style="-fx-background-color: #961111; -fx-padding: 8 20;"/>
                <Button fx:id="btnWhatsAppSelected" text=" WHATSAPP SELECTED TESTS" onAction="#handleWhatsAppSelectedTests"
                        visible="false" managed="false" styleClass="button-secondary" style="-fx-background-color: #008080; -fx-padding: 8 20;"/>
            </HBox>

    </VBox>

</VBox>
