<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="620.0" prefWidth="450.0" spacing="15.0" style="-fx-background-color: #F9F2F2;" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lab.lms.controllers.RateListController">
   <children>
      <!-- Header Area -->
      <VBox spacing="5.0" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-background-radius: 0 0 15 15;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="LABORATORY TEST CATALOGUE" style="-fx-text-fill: #961111; -fx-font-weight: bold; -fx-font-size: 16px;"/>
                        <Label text="Live Rate List &amp; Diagnostic Inventory" style="-fx-text-fill: #78909C; -fx-font-size: 11px;"/>
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <Separator prefWidth="200.0" style="-fx-padding: 10 0 5 0;"/>
            
            <HBox spacing="10.0" alignment="BOTTOM_LEFT">
               <children>
                  <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="QUICK SEARCH PROTOCOL" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <TextField fx:id="searchField" prefHeight="40.0" promptText="Search test name or category..." styleClass="medical-search-bar" style="-fx-background-radius: 8; -fx-border-radius: 8;"/>
                     </children>
                  </VBox>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="LENS / FILTER" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        <ComboBox fx:id="filterClassCombo" prefHeight="40.0" prefWidth="150.0" style="-fx-background-radius: 8;" />
                     </children>
                  </VBox>
                  <Button onAction="#handlePrint" prefHeight="40.0" text="PRINT LIST" styleClass="button-primary" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-background-color: #961111; -fx-text-fill: white; -fx-padding: 0 20;"/>
               </children>
            </HBox>
         </children>
      </VBox>
      
      <!-- Table Area -->
      <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 20 20 20;">
         <children>
            <TableView fx:id="rateTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-overflow-x: hidden;">
              <columns>
                <TableColumn fx:id="colNumericCode" prefWidth="80.0" text="CODE" />
                <TableColumn fx:id="colAlphaCode" prefWidth="100.0" text="ALPHA" />
                <TableColumn fx:id="colTestName" minWidth="200.0" prefWidth="350.0" text="DIAGNOSTIC TEST DESCRIPTION" />
                <TableColumn fx:id="colPrice" minWidth="100.0" prefWidth="120.0" text="PRICE (PKR)" style="-fx-alignment: CENTER-RIGHT;" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 5 0 0 0;">
               <children>
                  <Label fx:id="lblCount" text="Total Protocols: 0" style="-fx-text-fill: #78909C; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleRefresh" text="REFRESH" styleClass="button-secondary" style="-fx-font-size: 10px; -fx-padding: 5 15; -fx-background-color: #546E7A;"/>
               </children>
            </HBox>
         </children>
      </VBox>
      
      <!-- Footer Branding -->
      <HBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #2c3e50;">
         <children>
            <Label text="POWERED BY MSF DIGITAL SOLUTIONS - CLINICAL ENGINE" style="-fx-text-fill: white; -fx-font-size: 9px; -fx-font-weight: bold;"/>
         </children>
      </HBox>
   </children>
</VBox>
